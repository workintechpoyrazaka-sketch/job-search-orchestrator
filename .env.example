# Copy to .env (gitignored) and fill in real values. Never commit .env.
# OPERATOR_TOKEN: generate once with
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OPERATOR_TOKEN=replace-me
# DATABASE_URL must authenticate as orchestrator_app (password via ~/.pgpass,
# NOT in the DSN) — that is what makes the SET LOCAL ROLE boundary real.
DATABASE_URL=postgresql://orchestrator_app@localhost/orchestrator
